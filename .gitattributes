# 自动处理文本文件，统一仓库换行符为 LF
* text=auto eol=lf

# 明确声明源码文件始终使用 LF
*.py    text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.sh    text eol=lf
*.git*  text eol=lf

# 二进制文件（不处理换行）
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.pdf   binary
*.zip   binary
*.tar   binary
*.gz    binary
*.bz2   binary